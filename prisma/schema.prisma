generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  username        String         @unique
  passwordHash    String
  name            String
  phone           String
  email           String?
  businessName    String?
  businessAddress String?
  businessId      String?
  businessType    String?
  role            Role           @default(CUSTOMER)
  notes           String?
  createdAt       DateTime       @default(now())
  lastLogin       DateTime?
  requests        QuoteRequest[]
  messages        Message[]
  favorites       Favorite[]
  stockAlerts     StockAlert[]
}

enum Role {
  CUSTOMER
  VIP
  ADMIN
}

model QuoteRequest {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  guestName      String?
  guestPhone     String?
  carMake        String
  carModel       String
  carYear        String
  position       Position
  licensePlate   String?   // מספר רכב
  catalogNumber  String?   // מק"ט מהקטלוג (אם הבקשה הגיעה מעמוד מוצר)
  notes          String?
  imageUrl       String?
  status         Status    @default(PENDING)
  quotedPrice    Float?
  createdAt      DateTime  @default(now())
  closedAt       DateTime?
  messages       Message[]
}

enum Position {
  FRONT
  REAR
}

enum Status {
  PENDING
  QUOTED
  CLOSED
  CANCELLED
}

model Message {
  id         String        @id @default(cuid())
  requestId  String?       // null = free conversation (not tied to a request)
  request    QuoteRequest? @relation(fields: [requestId], references: [id])
  userId     String?
  user       User?         @relation(fields: [userId], references: [id])
  senderRole String
  content    String?
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime      @default(now())

  @@index([userId, requestId, createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bumperId  String   // mondayItemId from BumperCache
  createdAt DateTime @default(now())

  @@unique([userId, bumperId])
}

model ImageCache {
  id        String   @id @default(cuid())
  assetId   String   @unique
  publicUrl String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model StockAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  carMake   String
  carModel  String
  carYear   String?
  position  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SystemEvent {
  id          String   @id @default(cuid())
  level       String   // "info" | "warn" | "error" | "critical"
  source      String   // "monday_sync" | "whatsapp" | "auth" | "api" | "db" | "health"
  message     String
  details     String?  // JSON stringified extra data
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  autoHealed  Boolean  @default(false) // was it auto-fixed?
  healAction  String?  // what self-heal action was taken
  createdAt   DateTime @default(now())

  @@index([level, createdAt])
  @@index([source, createdAt])
  @@index([resolved, createdAt])
}

model HealthCheck {
  id          String   @id @default(cuid())
  status      String   // "healthy" | "degraded" | "down"
  dbOk        Boolean
  mondayOk    Boolean
  pusherOk    Boolean
  details     String?  // JSON
  responseMs  Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model BumperView {
  id           String   @id @default(cuid())
  bumperId     String   // mondayItemId from BumperCache
  userId       String?  // null = anonymous visitor
  sessionId    String?  // for anonymous tracking
  createdAt    DateTime @default(now())

  @@index([bumperId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  sessionId String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
}

model BumperCache {
  id           String    @id @default(cuid())
  mondayItemId String    @unique
  name         String
  carMake      String
  carModel     String
  carYear      String
  position     Position?
  price        Float?
  status       String
  imageUrl     String?
  imageUrls    String[]  @default([])
  lastSynced   DateTime  @updatedAt
}
